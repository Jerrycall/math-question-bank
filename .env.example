# ========== 数据库连接（必填） ==========
# 格式：postgresql://用户名:密码@主机:端口/数据库名?schema=public
# 本地示例：
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/math_question_bank?schema=public"
# 若端口、用户名、密码不同，请修改上面三个部分。

# ========== 可选 ==========
REDIS_URL="redis://localhost:6379"

# --- AI：OpenAI 官方（默认）---
OPENAI_API_KEY="sk-..."

# --- 或：对话用 DeepSeek（OpenAI 兼容），向量相似题仍建议用 OpenAI embedding ---
# AI_API_BASE_URL="https://api.deepseek.com"
# AI_API_KEY="你的 DeepSeek API Key"
# AI_CHAT_MODEL="deepseek-chat"
# OPENAI_API_KEY="sk-... 仅用于 text-embedding（相似题/结构化写向量）"

# --- 可选覆盖 ---
# AI_CHAT_MODEL="gpt-4o"
# AI_EMBEDDING_API_KEY=""
# AI_EMBEDDING_BASE_URL=""
# AI_EMBEDDING_MODEL="text-embedding-3-small"
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# 登录会话（Cookie 签名）
SESSION_SECRET="your-session-secret-here"

# 管理员后台：逗号分隔的用户名，这些账号可访问 /admin 并管理用户与题集
# ADMIN_USERNAMES="admin,root"
ADMIN_USERNAMES=""
