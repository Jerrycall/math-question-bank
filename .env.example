# ========== 数据库连接（必填） ==========
# 格式：postgresql://用户名:密码@主机:端口/数据库名?schema=public
# 本地示例：
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/math_question_bank?schema=public"
# 若端口、用户名、密码不同，请修改上面三个部分。

# ========== 可选 ==========
REDIS_URL="redis://localhost:6379"
OPENAI_API_KEY="sk-..."
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"
